# Copy to .env and fill in values.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scentra?schema=public"

# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET="change-me-minimum-sixteen-chars!!"
JWT_REFRESH_SECRET=""

JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

PORT=3000
NODE_ENV=development

# Comma-separated origins, or * for any (dev only)
CORS_ORIGIN="*"

# Optional: Google Sign-In (Expo sends ID token to POST /api/auth/google)
GOOGLE_CLIENT_ID=""

# Public URL for uploaded file responses (defaults to http://localhost:PORT)
PUBLIC_BASE_URL="http://localhost:3000"
