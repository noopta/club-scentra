entrypoint = "README.md"
modules = ["nodejs-22"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[[ports]]
localPort = 5904
externalPort = 3001

[[ports]]
localPort = 8082
externalPort = 3000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Dev Server"
mode = "sequential"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_DEV_SERVER_ORIGIN=https://$REPLIT_DEV_DOMAIN npx expo start --web --port 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "EAS Init"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx eas init"

[[workflows.workflow]]
name = "EAS Publish Preview iOS"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx eas build --platform ios --profile preview --non-interactive"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dev Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "EAS Publish Preview iOS"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "EAS Submit iOS (TestFlight)"

[[workflows.workflow]]
name = "EAS Submit iOS (TestFlight)"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "EXPO_TOKEN=$EXPO_TOKEN EXPO_APPLE_APP_SPECIFIC_PASSWORD=$EXPO_APPLE_APP_SPECIFIC_PASSWORD npx eas submit --platform ios --latest --profile production --non-interactive"

[agent]
expertMode = true

[deployment]
deploymentTarget = "autoscale"
build = ["npx", "expo", "export", "--platform", "web"]
publicDir = "dist"
run = ["npx", "serve", "dist", "--listen", "5000"]
